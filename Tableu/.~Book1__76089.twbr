      <column caption='Churn Flag' datatype='integer' name='[Calculation_4336122073761480704]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Churn] = &quot;Yes&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Churn Rate' datatype='real' default-format='p0.00%' name='[Calculation_4336122073761636353]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_4336122073761480704]) / COUNT([customerID])' />
      </column>
      <column caption='Tenure Group' datatype='string' name='[Calculation_4336122073761927170]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [tenure] &lt; 12 THEN &quot;Short&quot;&#10;ELSEIF [tenure] &lt;= 48 THEN &quot;Medium&quot;&#10;ELSE &quot;Long&quot;&#10;END' />
      </column>
      <column caption='Customer segment' datatype='string' name='[Calculation_4336122073762050051]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [MonthlyCharges] &gt; 80 THEN &quot;High Value&quot;&#10;ELSEIF [MonthlyCharges] &gt; 40 THEN &quot;Medium Value&quot;&#10;ELSE &quot;Low Value&quot;&#10;END' />
